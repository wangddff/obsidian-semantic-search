# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================
# 项目特定文件
# ============================================

# 向量数据库文件
*.lancedb
*.parquet
*.feather
*.arrow
*.db
*.sqlite
*.sqlite3

# 数据目录（排除大文件，但保留目录结构）
data/embeddings/
data/index/
data/test_results/raw/
data/test_results/vectors/

# 临时文件
/tmp/
temp/
tmp/
*.tmp
*.temp

# 日志文件
*.log
logs/
log/

# 配置文件（敏感信息）
config.local.yaml
*.local.yaml
secrets.yaml
.env.local
.env.*.local

# ============================================
# 测试和构建文件
# ============================================

# 测试数据
test_data/
test_output/

# 构建输出
build/
dist/
*.exe
*.dll
*.pyd

# 文档构建
docs/_build/
site/

# ============================================
# 机器学习/深度学习
# ============================================

# PyTorch
*.pth
*.pt
*.bin

# TensorFlow
*.pb
*.meta
*.index
*.data-*

# 模型文件
*.h5
*.keras
*.joblib
*.pkl
*.pickle

# ============================================
# 其他
# ============================================

# 压缩文件
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# 二进制文件
*.dmg
*.iso
*.img

# 证书文件
*.pem
*.crt
*.key
*.pfx

# 备份文件
*.bak
*.backup
*.old

# ============================================
# 需要保留的文件（例外规则）
# ============================================

# 保留空的data目录结构
!data/
!data/.gitkeep

# 保留测试数据目录结构
!data/test_results/
!data/test_results/.gitkeep

# 保留配置文件（但不包含敏感信息）
!config/
!config/config.yaml
!config/.gitkeep

# ============================================
# 项目特定例外
# ============================================

# 保留requirements.txt
!requirements.txt

# 保留所有Python源代码
!src/
!src/*.py

# 保留所有测试文件
!test_*.py
!tests/
!tests/*.py

# 保留文档文件
!*.md
!docs/
!docs/*.md

# 保留演示文件
!demo_*.py
!quick_*.py

# ============================================
# 自定义规则
# ============================================

# 排除个人配置文件
personal_config.yaml
user_settings.yaml

# 排除API密钥文件
api_keys.yaml
secrets.json
credentials.json

# 排除大型数据集
large_dataset/
*.csv.gz
*.json.gz

# 排除模型检查点
checkpoints/
*.ckpt

# 排除训练日志
training_logs/
runs/
wandb/

# ============================================
# 最后：确保.gitignore本身不被忽略
# ============================================
!.gitignore